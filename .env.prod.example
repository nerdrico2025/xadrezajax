# =============================================================
# Copie para .env.prod e preencha com seus valores reais.
# NUNCA commite o .env.prod — ele fica só no servidor.
# =============================================================

# ─────────────────────────────────────────
# Domínio
# ─────────────────────────────────────────
DOMAIN=seudominio.com
ADMIN_EMAIL=admin@seudominio.com

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
DB_NAME=xadrez_db
DB_USER=xadrez_user
DB_PASSWORD=troque-por-senha-forte-aqui
DB_HOST=postgres
DB_PORT=5432

# ─────────────────────────────────────────
# Django
# Gere uma SECRET_KEY forte com:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# ─────────────────────────────────────────
SECRET_KEY=troque-por-chave-gerada-com-secrets.token_urlsafe
DEBUG=False
ALLOWED_HOSTS=seudominio.com
CORS_ALLOWED_ORIGINS=https://seudominio.com

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────
# Node API
# ─────────────────────────────────────────
NODE_ENV=production
NODE_PORT=3000
