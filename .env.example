# =============================================================
# Copie para .env e preencha com seus valores reais
# =============================================================

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
DB_NAME=xadrez_db
DB_USER=xadrez_user
DB_PASSWORD=xadrez_password
DB_HOST=postgres
DB_PORT=5432

# ─────────────────────────────────────────
# Django
# ─────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────
# Node API
# ─────────────────────────────────────────
NODE_ENV=development
NODE_PORT=3000

# ─────────────────────────────────────────
# Mobile (Expo)
# Execute: hostname -I | awk '{print $1}' para descobrir seu IP
# ─────────────────────────────────────────
HOST_IP=192.168.x.x
