# =============================================================
# Copie para .env e preencha com seus valores reais
# =============================================================

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
DB_NAME=xadrez_db
DB_USER=xadrez_user
DB_PASSWORD=xadrez_password
DB_HOST=postgres
DB_PORT=5432

# ─────────────────────────────────────────
# Django
# ─────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────
# Node API
# ─────────────────────────────────────────
NODE_ENV=development
NODE_PORT=3000

# ─────────────────────────────────────────
# Stripe (assinaturas — item 0.1)
# STRIPE_WEBHOOK_SECRET só existe depois de cadastrar o endpoint
# /api/v1/payments/stripe/webhook/ no Dashboard do Stripe — o app
# sobe sem ela (a view do webhook responde erro claro até configurar).
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_ID_MENSAL=price_xxx
STRIPE_PRICE_ID_ANUAL=price_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─────────────────────────────────────────
# Mobile (Expo)
# Execute: hostname -I | awk '{print $1}' para descobrir seu IP
# ─────────────────────────────────────────
HOST_IP=192.168.x.x
# EXPO_PUBLIC_API_URL=http://192.168.x.x:8000
# EXPO_PUBLIC_NODE_URL=http://192.168.x.x:3000

EXPO_PUBLIC_API_URL=https://consult-spongy-ivy.ngrok-free.dev 

