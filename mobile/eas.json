{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.0.128:8000",
        "EXPO_PUBLIC_NODE_URL": "http://192.168.0.128:3000",
        "EXPO_PUBLIC_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://django.ajaxclube.com.br",
        "EXPO_PUBLIC_NODE_URL": "https://node.ajaxclube.com.br",
        "EXPO_PUBLIC_ENV": "preview"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://django.ajaxclube.com.br",
        "EXPO_PUBLIC_NODE_URL": "https://node.ajaxclube.com.br",
        "EXPO_PUBLIC_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
